# Copy to .env (gitignored) and fill in the values from your Azure AD app registration.
# See GRAPH_SETUP.md for how to obtain these.

AZURE_TENANT_ID={{secrets.TENANT_ID}}
AZURE_CLIENT_ID={{secrets.CLIENT_ID}}
AZURE_CLIENT_SECRET={{secrets.CLIENT_SECRET}}

# Existing SQL vars (leave blank if not using the DB locally)
SQL_USERNAME=
SQL_PASSWORD=
SQL_SERVER=
SQL_DATABASE=
